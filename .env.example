# =============================================================================
# FinApp — Environment Configuration Example
# =============================================================================

# Server port (inside container and mapped to host)
PORT=6253

# Database connection string (PostgreSQL inside Docker network)
# Format: postgres://USER:PASSWORD@host:5432/DBNAME
DATABASE_URL=postgres://finapp:finapp@db:5432/finapp

# PostgreSQL SSL/TLS settings
# Set DATABASE_SSL=true for external managed Postgres (e.g., DigitalOcean, AWS RDS, Supabase)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# JWT secrets — CHANGE THESE for production!
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Token lifetimes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Timezone for Node.js and PostgreSQL timestamps
# Examples: UTC, Europe/Moscow, Europe/Berlin, America/New_York
TZ=UTC

# =============================================================================
# Optional
# =============================================================================
# Allowed CORS origins (comma-separated). Leave empty for same-origin.
ALLOWED_ORIGINS=

# Container runtime user/group IDs (default 1000:1000).
# Set these to match the host user that owns mounted files/backups.
PUID=1000
PGID=1000

